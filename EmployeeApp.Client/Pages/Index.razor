@page "/"
@using EmployeeApp.Shared
@using EmployeeApp.Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject EmployeeService EmployeeService
@inject NavigationManager Navigation

<PageTitle>Employee Management</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Employees</h1>
        <AuthorizeView Roles="Admin">
            <button class="btn btn-primary" @onclick="() => { isReadOnly = false; ShowEmployeeModal(); }">Add New Employee</button>
        </AuthorizeView>
    </div>

    @if (employees == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!employees.Any())
    {
        <div class="alert alert-info">No employees found.</div>
    }
    else
    {
        <table class="table table-striped table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Email</th>
                    <th>Department</th>
                    <th>Designation</th>
                    <th>Salary</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in employees)
                {
                    <tr>
                        <td>@emp.FirstName</td>
                        <td>@emp.LastName</td>
                        <td>@emp.Email</td>
                        <td>@emp.Department</td>
                        <td>@emp.Designation</td>
                        <td>@emp.Salary.ToString("C")</td>
                        <td>
                            <div class="btn-group">
                                <button class="btn btn-sm btn-info text-white" @onclick="() => ShowDetails(emp)">Details</button>
                                <AuthorizeView Roles="Admin">
                                    <button class="btn btn-sm btn-warning" @onclick="() => { isReadOnly = false; ShowEmployeeModal(emp); }">Edit</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(emp)">Delete</button>
                                </AuthorizeView>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (showModal)
{
    <div class="modal fade show" style="display:block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(currentEmployee.Id == 0 ? "Add" : (isReadOnly ? "Employee Details" : "Edit Employee"))</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="currentEmployee" OnValidSubmit="SaveEmployee">
                        <DataAnnotationsValidator />
                        <div class="mb-3">
                            <label class="form-label">First Name</label>
                            <InputText @bind-Value="currentEmployee.FirstName" class="form-control" disabled="@isReadOnly" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Last Name</label>
                            <InputText @bind-Value="currentEmployee.LastName" class="form-control" disabled="@isReadOnly" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <InputText @bind-Value="currentEmployee.Email" class="form-control" disabled="@isReadOnly" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Department</label>
                            <InputText @bind-Value="currentEmployee.Department" class="form-control" disabled="@isReadOnly" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Designation</label>
                            <InputText @bind-Value="currentEmployee.Designation" class="form-control" disabled="@isReadOnly" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Salary</label>
                            <InputNumber @bind-Value="currentEmployee.Salary" class="form-control" disabled="@isReadOnly" />
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                            @if (!isReadOnly)
                            {
                                <button type="submit" class="btn btn-primary">Save changes</button>
                            }
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (showDeleteModal)
{
    <div class="modal fade show" style="display:block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CloseDeleteModal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete employee <strong>@deleteEmpName</strong>?</p>
                    <p class="text-danger">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDeleteModal">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteEmployee">Delete</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<Employee>? employees;
    private Employee currentEmployee = new();
    private bool showModal = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployees();
    }

    private bool showDeleteModal = false;
    private int deleteEmpId = 0;
    private string deleteEmpName = "";
    private bool isReadOnly = false;

    private async Task LoadEmployees()
    {
        try
        {
            employees = await EmployeeService.GetEmployees();
        }
        catch (Exception ex)
        {
            // Handle error (e.g., unauthorized)
            if (ex.Message.Contains("401"))
            {
                Navigation.NavigateTo("/login");
            }
        }
    }

    private void ShowDetails(Employee employee)
    {
        isReadOnly = true;
        ShowEmployeeModal(employee);
    }

    private void ConfirmDelete(Employee employee)
    {
        deleteEmpId = employee.Id;
        deleteEmpName = $"{employee.FirstName} {employee.LastName}";
        showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        showDeleteModal = false;
        deleteEmpId = 0;
        deleteEmpName = "";
    }

    private void ShowEmployeeModal(Employee? employee = null)
    {
        if (employee != null)
        {
            currentEmployee = new Employee
            {
                Id = employee.Id,
                FirstName = employee.FirstName,
                LastName = employee.LastName,
                Email = employee.Email,
                Department = employee.Department,
                Designation = employee.Designation,
                Salary = employee.Salary,
                DateOfJoining = employee.DateOfJoining
            };
        }
        else
        {
            currentEmployee = new Employee();
        }
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task SaveEmployee()
    {
        if (currentEmployee.Id == 0)
        {
            await EmployeeService.CreateEmployee(currentEmployee);
        }
        else
        {
            await EmployeeService.UpdateEmployee(currentEmployee.Id, currentEmployee);
        }
        showModal = false;
        await LoadEmployees();
    }

    private async Task DeleteEmployee()
    {
        if (deleteEmpId != 0)
        {
            await EmployeeService.DeleteEmployee(deleteEmpId);
            await LoadEmployees();
            CloseDeleteModal();
        }
    }
}
