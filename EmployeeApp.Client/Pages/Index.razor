@page "/index"
@using EmployeeApp.Shared
@using EmployeeApp.Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject EmployeeService EmployeeService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Employees - Management System</PageTitle>

<div class="bg-dark text-light min-vh-100 py-5">

    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-outline-light"
                        @onclick="GoToHome">
                    <i class="bi bi-house-door me-2"></i>
                    Home
                </button>

                <h2 class="fw-bold text-danger mb-0 mx-5">
                    <u>Employee Dashboard</u>
                </h2>
            </div>

    <AuthorizeView Roles="Admin">
        <button class="btn btn-danger px-4 shadow"
                @onclick="() => { isReadOnly = false; ShowEmployeeModal(); }">
            + Add Employee
        </button>
    </AuthorizeView>

</div>

        @if (employees == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-danger"></div>
            </div>
        }
        else if (!employees.Any())
        {
            <div class="alert alert-dark border border-secondary text-light">
                No employees found.
            </div>
        }
        else
        {
            <div class="table-responsive shadow rounded-4 border border-secondary">
                <table class="table table-dark table-hover align-middle mb-0">
                    <thead class="border-bottom border-danger">
                        <tr>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Designation</th>
                            <th>Salary</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var emp in employees)
                        {
                            <tr>
                                <td>@emp.FirstName</td>
                                <td>@emp.LastName</td>
                                <td class="text-secondary">@emp.Email</td>
                                <td>@emp.Department</td>
                                <td>@emp.Designation</td>
                                <td class="text-success fw-semibold">@emp.Salary.ToString("C")</td>
                                <td class="text-center">
                                    <div class="btn-group">

                                        <button class="btn btn-sm btn-outline-info"
                                                @onclick="() => ShowDetails(emp)">
                                            Details
                                        </button>

                                        <AuthorizeView Roles="Admin">
                                            <button class="btn btn-sm btn-outline-warning"
                                                    @onclick="() => { isReadOnly = false; ShowEmployeeModal(emp); }">
                                                Edit
                                            </button>

                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => ConfirmDelete(emp)">
                                                Delete
                                            </button>
                                        </AuthorizeView>

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>

@if (showModal)
{
    <div class="modal fade show" style="display:block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content bg-black text-light border border-danger rounded-4">

                <div class="modal-header border-bottom border-danger">
                    <h5 class="modal-title text-danger">
                        @(currentEmployee.Id == 0 ? "Add Employee" :
                                            (isReadOnly ? "Employee Details" : "Edit Employee"))
                    </h5>
                    <button type="button"
                            class="btn-close btn-close-white"
                            @onclick="CloseModal">
                    </button>
                </div>

                <div class="modal-body">

                    <EditForm Model="currentEmployee" OnValidSubmit="SaveEmployee">
                        <DataAnnotationsValidator />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-secondary">First Name</label>
                                <InputText @bind-Value="currentEmployee.FirstName"
                                           class="form-control bg-dark text-light border-secondary"
                                           disabled="@isReadOnly" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label text-secondary">Last Name</label>
                                <InputText @bind-Value="currentEmployee.LastName"
                                           class="form-control bg-dark text-light border-secondary"
                                           disabled="@isReadOnly" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-secondary">Email</label>
                            <InputText @bind-Value="currentEmployee.Email"
                                       class="form-control bg-dark text-light border-secondary"
                                       disabled="@isReadOnly" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-secondary">Department</label>
                                <InputText @bind-Value="currentEmployee.Department"
                                           class="form-control bg-dark text-light border-secondary"
                                           disabled="@isReadOnly" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label text-secondary">Designation</label>
                                <InputText @bind-Value="currentEmployee.Designation"
                                           class="form-control bg-dark text-light border-secondary"
                                           disabled="@isReadOnly" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-secondary">Salary</label>
                                <InputNumber @bind-Value="currentEmployee.Salary"
                                             class="form-control bg-dark text-light border-secondary"
                                             disabled="@isReadOnly" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label text-secondary">Date of Joining</label>
                                <InputDate @bind-Value="currentEmployee.DateOfJoining"
                                           class="form-control bg-dark text-light border-secondary"
                                           disabled="@isReadOnly" />
                            </div>
                        </div>

                        <div class="modal-footer border-top border-secondary">
                            <button type="button"
                                    class="btn btn-outline-light"
                                    @onclick="CloseModal">
                                Close
                            </button>

                            @if (!isReadOnly)
                            {
                                <button type="submit" class="btn btn-danger">
                                    Save Changes
                                </button>
                            }
                        </div>

                    </EditForm>

                </div>
            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}

@if (showDeleteModal)
{
    <div class="modal fade show" style="display:block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content bg-black text-light border border-danger rounded-4">

                <div class="modal-header border-bottom border-danger">
                    <h5 class="modal-title text-danger">
                        Confirm Delete
                    </h5>
                    <button type="button"
                            class="btn-close btn-close-white"
                            @onclick="CloseDeleteModal">
                    </button>
                </div>

                <div class="modal-body">
                    <p>
                        Are you sure you want to delete
                        <strong class="text-danger">@deleteEmpName</strong>?
                    </p>
                    <p class="text-secondary">
                        This action cannot be undone.
                    </p>
                </div>

                <div class="modal-footer border-top border-secondary">
                    <button class="btn btn-outline-light"
                            @onclick="CloseDeleteModal">
                        Cancel
                    </button>

                    <button class="btn btn-danger"
                            @onclick="DeleteEmployee">
                        Delete
                    </button>
                </div>

            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<Employee>? employees;
    private Employee currentEmployee = new();
    private bool showModal = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployees();
    }

    private bool showDeleteModal = false;
    private int deleteEmpId = 0;
    private string deleteEmpName = "";
    private bool isReadOnly = false;

    private async Task LoadEmployees()
    {
        try
        {
            employees = await EmployeeService.GetEmployees();
        }
        catch (Exception ex)
        {
            // Handle error (e.g., unauthorized)
            if (ex.Message.Contains("401"))
            {
                Navigation.NavigateTo("/login");
            }
        }
    }

    private void ShowDetails(Employee employee)
    {
        isReadOnly = true;
        ShowEmployeeModal(employee);
    }

    private void ConfirmDelete(Employee employee)
    {
        deleteEmpId = employee.Id;
        deleteEmpName = $"{employee.FirstName} {employee.LastName}";
        showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        showDeleteModal = false;
        deleteEmpId = 0;
        deleteEmpName = "";
    }

    private void ShowEmployeeModal(Employee? employee = null)
    {
        if (employee != null)
        {
            currentEmployee = new Employee
            {
                Id = employee.Id,
                FirstName = employee.FirstName,
                LastName = employee.LastName,
                Email = employee.Email,
                Department = employee.Department,
                Designation = employee.Designation,
                Salary = employee.Salary,
                DateOfJoining = employee.DateOfJoining
            };
        }
        else
        {
            currentEmployee = new Employee();
        }
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task SaveEmployee()
    {
        try
        {
            if (currentEmployee.Id == 0)
            {
                await EmployeeService.CreateEmployee(currentEmployee);
                await JSRuntime.InvokeVoidAsync("alert", "Employee added successfully!");
            }
            else
            {
                await EmployeeService.UpdateEmployee(currentEmployee.Id, currentEmployee);
                await JSRuntime.InvokeVoidAsync("alert", "Employee updated successfully!");
            }
            showModal = false;
            await LoadEmployees();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error saving employee: " + ex.Message);
        }
    }

    private async Task DeleteEmployee()
    {
        if (deleteEmpId != 0)
        {
            try
            {
                await EmployeeService.DeleteEmployee(deleteEmpId);
                await JSRuntime.InvokeVoidAsync("alert", "Employee deleted successfully!");
                await LoadEmployees();
                CloseDeleteModal();
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Error deleting employee: " + ex.Message);
            }
        }
    }
    private void GoToHome()
    {
        Navigation.NavigateTo("/");
    }
}
