@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<div class="bg-dark text-light min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-dark bg-black border-bottom border-danger shadow-sm px-5 py-3">
        <div class="container-fluid">

            <a class="navbar-brand fw-bold text-danger fs-4" href="/">
                🔥 Employee Management System
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="mainNav">
                <ul class="navbar-nav align-items-center gap-3">

                    <li class="nav-item">
                        <a class="nav-link text-light fw-semibold" href="/">Home</a>
                    </li>

                    <AuthorizeView>
                        <Authorized>
                            <li class="nav-item">
                                <button class="btn btn-outline-danger px-4"
                                        @onclick='() => Navigation.NavigateTo("/index")'>
                                    Employees
                                </button>
                            </li>
                        </Authorized>

                        <NotAuthorized>
                            <li class="nav-item">
                                <button class="btn btn-outline-danger px-4"
                                        @onclick="GoToLogin">
                                    Login
                                </button>
                            </li>

                            <li class="nav-item">
                                <button class="btn btn-danger px-4 shadow-sm"
                                        @onclick="GoToRegister">
                                    Register
                                </button>
                            </li>
                        </NotAuthorized>
                    </AuthorizeView>

                </ul>
            </div>

        </div>
    </nav>

    <div class="container d-flex align-items-center justify-content-center text-center"
         style="min-height:85vh;">

        <div class="col-lg-9">

            <h1 class="display-2 fw-bold text-danger mb-4">
                Secure Employee Management
            </h1>

            <p class="lead text-secondary mb-5 fs-4">
                Powered by .NET Core, SQL Server, JWT Authentication,
                Role-Based Authorization & Blazor WebAssembly.
            </p>

            <AuthorizeView>
                <Authorized>
                    <button class="btn btn-lg btn-danger px-5 py-3 shadow"
                            @onclick='() => Navigation.NavigateTo("/index")'>
                        Go to Dashboard
                    </button>
                </Authorized>

                <NotAuthorized>
                    <div class="d-flex justify-content-center gap-4">
                        <button class="btn btn-lg btn-danger px-5 py-3 shadow"
                                @onclick="GoToLogin">
                            Get Started
                        </button>

                        <button class="btn btn-lg btn-outline-light px-5 py-3" @
                                @onclick="GoToRegister">
                            Create Account
                        </button>
                    </div>
                </NotAuthorized>
            </AuthorizeView>

        </div>
    </div>

    <!-- FOOTER -->
    <footer class="text-center text-secondary py-4 border-top border-secondary">
        © @DateTime.Now.Year - Employee Management System
    </footer>

</div>


@code {

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private void GoToRegister()
    {
        Navigation.NavigateTo("/register");
    }

}
